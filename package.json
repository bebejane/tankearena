{
  "name": "tankearena",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo & pnpm run codegen",
    "dev:https": "next dev --turbo & pnpm workslocal",
    "workslocal": "workslocal http 3000 --name bebedigital",
    "workslocal:https": "workslocal http 3000 --name bebejane",
    "start": "next start",
    "preview": "pnpm run build && pnpm run start",
    "build": "pnpm i github:bebejane/next-dato-utils && next build",
    "build:dev": "next build",
    "dev:email": "PORT=4000 email dev",
    "codegen": "graphql-codegen --watch",
    "codegen:datocms": "pnpx @datocms/cli schema:generate ./types/datocms-cma.ts",
    "lint": "next lint",
    "reset": "rm -rf ./node_modules && rm -rf pnpm-lock.yaml && rm -rf .next && pnpm i",
    "reset:cache": "rm -rf .next/cache",
    "open": "open http://localhost:3000"
  },
  "dependencies": {
    "@base-ui-components/react": "1.0.0-rc.0",
    "@datocms/cma-client": "^5.3.0",
    "@datocms/cma-client-browser": "^5.3.0",
    "@datocms/cma-client-node": "^5.3.0",
    "@datocms/content-link": "^0.3.19",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@libsql/client": "^0.15.15",
    "@mux/mux-player-react": "^3.11.7",
    "@react-email/components": "1.0.1",
    "@vercel/functions": "^3.4.3",
    "@vercel/stega": "^1.1.0",
    "better-auth": "^1.5.1",
    "change-case": "^5.4.4",
    "classnames": "^2.5.1",
    "datocms-structured-text-utils": "^5.1.7",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.44.7",
    "eventsource-client": "^1.2.0",
    "extended-eventsource": "^2.1.0",
    "graphql": "^16.13.2",
    "js-cookie": "^3.0.5",
    "next": "16.2.9",
    "next-client-cookies": "^2.1.0",
    "next-dato-utils": "github:bebejane/next-dato-utils",
    "next-intl": "^4.8.3",
    "nuqs": "^2.8.9",
    "postmark": "^4.0.7",
    "react": "19.2.3",
    "react-datocms": "8.0.0",
    "react-dom": "19.2.3",
    "react-wrap-balancer": "^1.1.1",
    "reconnecting-eventsource": "^1.6.5",
    "sass": "1.93.2",
    "sharp": "^0.34.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.1.2",
    "@graphql-codegen/typed-document-node": "^6.1.6",
    "@graphql-codegen/typescript": "^5.0.8",
    "@graphql-codegen/typescript-document-nodes": "^5.0.8",
    "@graphql-codegen/typescript-graphql-files-modules": "^3.0.1",
    "@graphql-codegen/typescript-operations": "^5.0.8",
    "@parcel/watcher": "^2.5.6",
    "@react-email/preview-server": "5.0.1",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.9",
    "graphql-config": "^5.1.5",
    "prettier-plugin-css-order": "^2.2.0",
    "react-email": "5.0.1",
    "typescript": "^5.9.3"
